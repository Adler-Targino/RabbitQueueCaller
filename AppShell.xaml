<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RabbitQueueCaller.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RabbitQueueCaller.Views"
    Title="RabbitQueueCaller">

    <TabBar>

        <ShellContent
            Title="Consumer"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:ConsumerPage}"
            Route="ConsumerPage" />

        <ShellContent
            Title="Rabbit Configuration"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:ConfigurationPage}"
            Route="ConfigurationPage" />

    </TabBar>

</Shell>